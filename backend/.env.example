# MongoDB (required)
MONGODB_URI=mongodb://localhost:27017/farmsaarthi

# Android SMS gateway for OTP (your phone runs a gateway app exposing an HTTP API)
# Example: http://192.168.1.50:8080/send-sms
ANDROID_GATEWAY_URL=

# Razorpay (required for payments)
RAZORPAY_KEY_ID=rzp_live_xxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# JWT
JWT_SECRET=your_jwt_secret_key

# Optional
PORT=5000
FRONTEND_URL=http://localhost:5173
PROXIMITY_RADIUS_KM=10
